    hum.PlatformStand=false; hum.AutoRotate=false
    flyBV=Instance.new("BodyVelocity"); flyBV.Velocity=Vector3.zero
    flyBV.MaxForce=Vector3.new(1e6,1e6,1e6); flyBV.P=1e6; flyBV.Parent=hrp
