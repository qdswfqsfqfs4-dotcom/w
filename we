-- AUTO GRAB (scan Attachment + ProximityPrompt partout)
local autoGrabEnabled=cfg.autoGrabEnabled; local grabRadius=cfg.grabRadius
local grabLast=0; local grabC

local function getAllPrompts()
    local h=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not h then return {} end
    local found={}; local seen={}
    -- Méthode 1: scan Plots descendants
    local plots=workspace:FindFirstChild("Plots")
    if plots then
        for _,plot in ipairs(plots:GetChildren()) do
            if isMyBase(plot.Name) then continue end
            for _,desc in ipairs(plot:GetDescendants()) do
                if desc:IsA("ProximityPrompt") and not seen[desc] then
                    local pt=desc.Parent
                    local pos=nil
                    if pt and pt:IsA("BasePart") then pos=pt.Position
                    elseif pt and pt:IsA("Attachment") then
                        local bp=pt.Parent; if bp and bp:IsA("BasePart") then pos=bp.Position end
                    end
                    if pos and (pos-h.Position).Magnitude<=grabRadius then
                        pcall(function() desc.MaxActivationDistance=9999; desc.RequiresLineOfSight=false; desc.HoldDuration=0 end)
                        seen[desc]=true; table.insert(found,desc)
                    end
                end
            end
        end
    end
    -- Méthode 2: scan workspace global (brainrots posés par terre, sur socles)
    for _,obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and not seen[obj] then
            local pt=obj.Parent; local pos=nil
            if pt and pt:IsA("BasePart") then pos=pt.Position
            elseif pt and pt:IsA("Attachment") then
                local bp=pt.Parent; if bp and bp:IsA("BasePart") then pos=bp.Position end
            end
            if pos and (pos-h.Position).Magnitude<=grabRadius then
                pcall(function() obj.MaxActivationDistance=9999; obj.RequiresLineOfSight=false; obj.HoldDuration=0 end)
                seen[obj]=true; table.insert(found,obj)
            end
        end
    end
    return found
end

local function startGrab()
    if grabC then grabC:Disconnect() end
    grabC=RunService.Heartbeat:Connect(function()
        if not autoGrabEnabled then return end
        local now=tick(); if now-grabLast<0.03 then return end; grabLast=now
        for _,p in ipairs(getAllPrompts()) do
            task.spawn(function() pcall(function() fireproximityprompt(p) end) end)
        end
    end)
end
local function setGrab(s)
    autoGrabEnabled=s; cfg.autoGrabEnabled=s
