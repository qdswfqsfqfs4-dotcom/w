local function tpTo(pos)
    local r=getRoot(); if not r then return false end
    equip("Flying Carpet"); task.wait(0.08); r=getRoot(); if not r then return false end
    r.AssemblyLinearVelocity=Vector3.new(); r.CFrame=CFrame.new(pos); task.wait(0.15); unAll(); task.wait(0.06); return true
end
local function tpToEntry(e) local mp=e.pos or getPos(e.model); if not mp then return end; task.spawn(function() if not tpTo(mp+Vector3.new(0,3,0)) then local r=getRoot(); if r then r.CFrame=CFrame.new(mp+Vector3.new(0,3,0)) end end end) end
local function stealEntry(e)
    local mp=e.pos or getPos(e.model); if not mp then return end
    local bp=getBaseSpawn(); if not bp then return end
    task.spawn(function()
        if not tpTo(mp+Vector3.new(0,3,0)) then local r=getRoot(); if r then r.CFrame=CFrame.new(mp+Vector3.new(0,3,0)) end end
        task.wait(0.2)
        local stop=tick()+2.5
        while tick()<stop do for _,p in ipairs(getAllPrompts()) do task.spawn(function() pcall(function() fireproximityprompt(p) end) end) end; task.wait(0.03) end
        local r=getRoot(); if r then tpTo(bp+Vector3.new(0,3,0)) end
    end)
end
local function getBest() local r=serverScan(); for _,e in ipairs(r) do return e end end
local function doSteal() local b=getBest(); if b then stealEntry(b) end end
local function doTP() local b=getBest(); if b then tpToEntry(b) end end

local switchOn=cfg.switchSteal; local switchRunning=false
local function setSwitch(s)
    switchOn=s; cfg.switchSteal=s; switchRunning=s
    if s then task.spawn(function()
        while switchRunning and switchOn do local b=getBest(); if b then stealEntry(b) end; task.wait(5) end
    end) end
end
local function doInstantLeave() task.spawn(function() doSteal(); task.wait(4.5); game:Shutdown() end) end

