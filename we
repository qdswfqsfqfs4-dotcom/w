local scanBusy=false; local lastScan={}
local MIN_VALUE=cfg.minShowValue or 2500000

local function serverScan()
    if scanBusy then return lastScan end
    scanBusy=true; local results={}
    local Plots=workspace:FindFirstChild("Plots")
    if not Plots then scanBusy=false; return results end
    local myChar=plr.Character; local myBp=plr.Backpack; local hrp=getHRP()
    for _,plot in ipairs(Plots:GetChildren()) do
        if not plot:IsA("Model") then continue end
        if isMyBase(plot.Name) then continue end
        local hasFuse=false
        for _,desc in ipairs(plot:GetDescendants()) do
            local dn=desc.Name:lower()
            if dn:find("fuse",1,true) or dn:find("fusion",1,true) then hasFuse=true; break end
        end
        if hasFuse then continue end
        local owner=getOwner(plot); local seen={}
        for _,br in ipairs(plot:GetDescendants()) do
            if not br:IsA("Model") then continue end
            if myChar and br:IsDescendantOf(myChar) then continue end
            if myBp and br:IsDescendantOf(myBp) then continue end
            local ad=AD[br.Name]; if not ad then continue end
            local pps=getVal(ad); if pps<MIN_VALUE then continue end
            local pos=getPos(br); if not pos then continue end
            local key=br.Name..math.floor(pos.X)..math.floor(pos.Z)
            if seen[key] then continue end; seen[key]=true
            local dist=hrp and math.floor((pos-hrp.Position).Magnitude) or 0
            local n=br.Name:lower()
            local isMuta=(n:find("muta")~=nil or n:find("evolved")~=nil or n:find("mega")~=nil)
            table.insert(results,{name=br.Name,value=pps,rarity=ad.Rarity or "Common",
                model=br,plot=plot,pos=pos,owner=owner,dist=dist,isMuta=isMuta})
        end
    end
    table.sort(results,function(a,b)
        if a.value~=b.value then return a.value>b.value end
        return(RO[a.rarity] or 0)>(RO[b.rarity] or 0)
    end)
    lastScan=results; scanBusy=false; return results
end

